rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // So permite leitura para usuarios autenticados que TAMBEM estejam na
    // allowlist usuarios_permitidos/{uid}. O app tem autocadastro (qualquer
    // um pode criar login), entao "request.auth != null" sozinho nao seria
    // suficiente - a allowlist e o que implementa a "aprovacao manual": so
    // e populada pelo Admin SDK (script Python do administrador, via
    // gerenciar_usuarios_firebase.py aprovar), nunca pelo client.
    function estaAutorizado() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/usuarios_permitidos/$(request.auth.uid));
    }

    // Admin fixo (uid do Neydson, neydson@petrobras.com.br) - so essa conta
    // consegue ler solicitacoes de outros usuarios e gravar em
    // usuarios_permitidos direto pelo navegador (tela de aprovacao em
    // index.html). Qualquer outro uid, mesmo autenticado, cai nas regras
    // normais abaixo (bloqueado).
    function souAdmin() {
      return request.auth != null &&
        request.auth.uid == "pfn8CD9zRSP0LpC0Tvv11G4lRmn1";
    }

    match /sessoes_alarme/{docId} {
      allow read: if estaAutorizado();
      allow write: if false;
    }
    match /sessoes_bypass/{docId} {
      allow read: if estaAutorizado();
      allow write: if false;
    }
    match /resumos_alarme/{docId} {
      allow read: if estaAutorizado();
      allow write: if false;
    }
    match /resumos_bypass/{docId} {
      allow read: if estaAutorizado();
      allow write: if false;
    }
    match /metadados/{docId} {
      allow read: if estaAutorizado();
      allow write: if false;
    }

    // So o admin pode ler a allowlist inteira (tela de aprovacao) ou
    // escrever nela (aprovar = criar entrada). Nenhum outro client, mesmo
    // autenticado e ja aprovado, consegue tocar aqui.
    match /usuarios_permitidos/{uid} {
      allow read, write: if souAdmin();
    }

    // Autocadastro: qualquer usuario autenticado pode CRIAR a propria
    // solicitacao (uid tem que bater com o dele mesmo) e ler o proprio
    // status - usado pela tela de "aguardando aprovacao". O admin pode ler
    // TODAS as solicitacoes (tela de aprovacao) e apagar (aprovar move pra
    // usuarios_permitidos e apaga daqui; rejeitar so apaga). Ninguem altera
    // depois de criada (evita se autoaprovar).
    match /solicitacoes_cadastro/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read: if (request.auth != null && request.auth.uid == uid) || souAdmin();
      allow delete: if souAdmin();
      allow update: if false;
    }

    // Default-deny explicito para qualquer colecao futura nao prevista aqui.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
