rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // So permite leitura para usuarios autenticados que TAMBEM estejam na
    // allowlist usuarios_permitidos/{uid}. O app tem autocadastro (qualquer
    // um pode criar login), entao "request.auth != null" sozinho nao seria
    // suficiente - a allowlist e o que implementa a "aprovacao manual": so
    // e populada pelo Admin SDK (script Python do administrador, via
    // gerenciar_usuarios_firebase.py aprovar), nunca pelo client.
    function estaAutorizado() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/usuarios_permitidos/$(request.auth.uid));
    }

    match /sessoes_alarme/{docId} {
      allow read: if estaAutorizado();
      allow write: if false;
    }
    match /sessoes_bypass/{docId} {
      allow read: if estaAutorizado();
      allow write: if false;
    }
    match /resumos_alarme/{docId} {
      allow read: if estaAutorizado();
      allow write: if false;
    }
    match /resumos_bypass/{docId} {
      allow read: if estaAutorizado();
      allow write: if false;
    }
    match /metadados/{docId} {
      allow read: if estaAutorizado();
      allow write: if false;
    }

    // Nunca legivel/gravavel diretamente pelo client - so usada
    // internamente por estaAutorizado() via exists(), que tem acesso
    // elevado dentro da propria regra.
    match /usuarios_permitidos/{uid} {
      allow read, write: if false;
    }

    // Autocadastro: qualquer usuario autenticado pode CRIAR a propria
    // solicitacao (uid tem que bater com o dele mesmo) e ler o proprio
    // status. Nunca pode alterar/apagar depois de criada (evita se
    // autoaprovar) - so o Admin SDK (script Python do administrador) move
    // a solicitacao para usuarios_permitidos ou apaga.
    match /solicitacoes_cadastro/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if false;
    }

    // Default-deny explicito para qualquer colecao futura nao prevista aqui.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
